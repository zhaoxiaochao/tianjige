      "author": "宋·邵雍（邵康节）所创",
      "timeMethod": {
        "name": "时间起卦法",
        "description": "以起卦时间的年月日时数字起卦",
        "steps": [
          "1. 记录起卦时间的农历年、月、日、时",
          "2. 年数：以地支序数代替（子1丑2寅3卯4辰5巳6午7未8申9酉10戌11亥12）",
          "3. 上卦 = （年数 + 月数 + 日数）÷ 8 取余数，余数对应先天八卦数",
          "4. 下卦 = （年数 + 月数 + 日数 + 时辰数）÷ 8 取余数",
          "5. 动爻 = （年数 + 月数 + 日数 + 时辰数）÷ 6 取余数",
          "6. 余数为0时，上下卦取8（坤），动爻取6（上爻）"
        ],
        "timeNumbers": {
          "子": 1,
          "丑": 2,
          "寅": 3,
          "卯": 4,
          "辰": 5,
          "巳": 6,
          "午": 7,
          "未": 8,
          "申": 9,
          "酉": 10,
          "戌": 11,
          "亥": 12
        },
        "example": {
          "time": "甲子年三月十五日午时",
          "calculation": {
            "yearNumber": 1,
            "monthNumber": 3,
            "dayNumber": 15,
            "hourNumber": 7,
            "upperTrigram": "(1+3+15) % 8 = 19 % 8 = 3 -> 离",
            "lowerTrigram": "(1+3+15+7) % 8 = 26 % 8 = 2 -> 兑",
            "movingLine": "(1+3+15+7) % 6 = 26 % 6 = 2 -> 第二爻动"
          }
        }
      },
      "numberMethod": {
        "name": "数字起卦法",
        "description": "以任意数字起卦",
