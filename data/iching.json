      "tiYongMethod": {
        "name": "体用法",
        "description": "梅花易数核心断卦方法",
        "concept": {
          "体卦": "不含动爻的经卦，代表自己、主体、问卦人",
          "用卦": "含有动爻的经卦，代表对方、客体、所问之事",
          "互卦": "二三四爻为下互卦，三四五爻为上互卦，代表事情发展过程",
          "变卦": "动爻变化后用卦所成的新经卦，代表事情结果"
        },
        "rules": [
          "动爻在上卦 -> 上卦为用卦，下卦为体卦",
          "动爻在下卦 -> 下卦为用卦，上卦为体卦"
        ],
        "interpretation": {
          "description": "以五行生克关系断吉凶",
          "rules": [
            {
              "pattern": "用生体",
              "result": "吉",
              "description": "对方有利于我，事情顺利，有收获"
            },
            {
              "pattern": "体生用",
              "result": "凶",
              "description": "我消耗于对方，有付出损失"
            },
            {
              "pattern": "用克体",
              "result": "凶",
              "description": "对方制约我，事情不利，有阻碍"
            },
            {
              "pattern": "体克用",
              "result": "吉",
              "description": "我制约对方，事情可成，有收获"
            },
            {
              "pattern": "体用比和",
              "result": "吉",
              "description": "双方和谐，事情平顺"
            }
          ]
        },
        "detailedInterpretation": {
          "description": "具体事项断法",
          "aspects": [
            {
              "aspect": "求财",
              "favorable": "体克用或用生体",
              "unfavorable": "用克体或体生用"
            },
            {
              "aspect": "婚姻",
              "favorable": "体用比和或用生体",
              "unfavorable": "体用相克"
            },
            {
              "aspect": "疾病",
              "favorable": "体旺且体克用",
              "unfavorable": "用克体且体弱"
            },
            {
              "aspect": "考试",
              "favorable": "用生体",
              "unfavorable": "体生用或用克体"
            },
            {
              "aspect": "诉讼",
              "favorable": "体克用且体旺",
              "unfavorable": "用克体"
            }
          ]
        }
      },
      "otherMethods": {
        "description": "其他起卦方法",
        "methods": [
          {
            "name": "声音起卦",
            "rule": "听到声响，以声数起卦"
          },
          {
            "name": "文字起卦",
            "rule": "以字的笔画数起卦"
          },
          {
            "name": "方位起卦",
            "rule": "以来人方位配先天八卦"
          },
          {
            "name": "颜色起卦",
            "rule": "以颜色对应五行起卦"
          },
          {
            "name": "随机起卦",
            "rule": "心有所感，随取数字起卦"
          }
        ]
      }
    }
